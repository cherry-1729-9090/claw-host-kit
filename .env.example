# Domain setup
OPENCLAW_BASE_DOMAIN=example.com
OPENCLAW_SUBDOMAIN=openclaw
OPENCLAW_HOST_SHARD=h1

# Traefik wildcard TLS — DNS-01 challenge via Cloudflare
# Create a scoped API token at https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone → DNS → Edit  (for your target zone only)
OPENCLAW_ACME_EMAIL=you@example.com
OPENCLAW_CF_DNS_API_TOKEN=replace_me

# Terminal token auth (HMAC secret — long random string)
OPENCLAW_TTYD_SECRET=replace_me_with_a_long_random_string
# Optional (seconds, default: 86400 = 24h)
OPENCLAW_TTYD_TTL_SECONDS=86400

# RAM limit enforced per container by vps-agent (MiB, default = 5120 = 5 GB)
OPENCLAW_CONTAINER_RAM_MB=5120

# Runtime image to run for instances (build locally or use your registry image)
OPENCLAW_RUNTIME_IMAGE=openclaw-ttyd:local

# Optional: Mem0 Cloud key. When set, every instance gets the openclaw-mem0 plugin
# wired up automatically and the key is passed into the container as MEM0_API_KEY.
OPENCLAW_MEM0_API_KEY=

# Optional: Composio Connect key. When set, every instance gets a
# workspace/config/mcporter.json file with a composio MCP server definition,
# and mcporter is installed in the runtime.
OPENCLAW_COMPOSIO_API_KEY=

# Optional: default model configuration. When set, every instance gets this
# custom provider written into openclaw.json and the primary model is forced to
# the normalized value below. For Cloudflare AI Gateway compat + Workers AI, the
# working primary model should include workers-ai/, for example:
# cloudflare-nemotron/workers-ai/@cf/nvidia/nemotron-3-120b-a12b
OPENCLAW_DEFAULT_PROVIDER_KEY=cloudflare-nemotron
OPENCLAW_DEFAULT_PROVIDER_BASE_URL=
OPENCLAW_DEFAULT_PROVIDER_API_KEY=
OPENCLAW_DEFAULT_PROVIDER_API=openai-completions
OPENCLAW_DEFAULT_PRIMARY_MODEL=cloudflare-nemotron/workers-ai/@cf/nvidia/nemotron-3-120b-a12b


# Control plane connection (optional — enables VPS self-registration on boot)
OPENCLAW_CONTROL_PLANE_URL=https://your-control-plane.example.com
OPENCLAW_INTERNAL_SECRET=replace_me_with_a_long_random_secret

# GitHub repo URL for openclaw-host-kit (used by cloud-init on new VPS nodes)
OPENCLAW_HOST_KIT_REPO=https://github.com/your-org/openclaw-host-kit.git
